    "express": "^4.18.2",
    "express-rate-limit": "^6.8.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.0",
    "node-cron": "^3.0.2",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "nodemon": "^2.0.22",
    "postcss": "^8.5.3",
    "supertest": "^7.1.0",
    "tailwindcss": "^3.4.17"
